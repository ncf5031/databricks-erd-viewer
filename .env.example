# ERD Viewer — Local Development Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These are only needed for local development (uvicorn app:app --reload).
# In Databricks Apps, these are set automatically via app.yaml and the runtime.

# Required: Your Databricks workspace URL
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net

# Required: SQL Warehouse ID for metadata queries
SQL_WAREHOUSE_ID=your_warehouse_id

# Optional: Override defaults
# CACHE_TTL_SECONDS=300
# CACHE_MAX_ENTRIES=1000
# MAX_TABLES_ON_CANVAS=100
# LOG_LEVEL=DEBUG

# Authentication for local dev:
# Option 1 (recommended): Configure a Databricks CLI profile
#   databricks auth login --host https://your-workspace.azuredatabricks.net
#   The backend uses the SDK's Config() which picks up CLI auth automatically.
#
# Option 2: Set a personal access token
# DATABRICKS_TOKEN=your_pat_token
