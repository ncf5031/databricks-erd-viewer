# ============================================================================
# Databricks Configuration (Local Overrides)
# ============================================================================
# Template files (databricks.yml, app.yaml) are tracked with placeholders
# Local overrides with real values should be ignored
.databricks/
databricks.local.yml
databricks.*.yml
app.local.yml
app.*.yml
*.local.yml
*.local.yaml

# Main configuration files
databricks.yml
backend/app.yaml

# Keep templates (placeholders for users)
!example.databricks.yml
!backend/example.app.yaml

# Databricks profiles (may contain tokens)
.databrickscfg

